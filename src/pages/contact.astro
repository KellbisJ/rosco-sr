---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- Hero with Embedded Form -->
  <section class="relative overflow-hidden bg-surface-alt py-24 sm:py-32">
    <!-- Decorative background elements -->
    <div
      class="absolute -left-32 -top-32 h-64 w-64 rounded-full bg-primary/5 blur-3xl">
    </div>
    <div
      class="absolute -bottom-32 -right-32 h-64 w-64 rounded-full bg-primary/5 blur-3xl">
    </div>

    <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl text-primary">
          Get in Touch
        </h1>
        <p class="mt-4 text-lg leading-8 text-text-body">
          Hard yakka ! 🛠️ At ROSCO S&R Need a professional touch for your site
          in Perth? Send us a message for a free quote today! 📞
        </p>
      </div>
      <div class="mx-auto mt-12 max-w-2xl">
        <div
          class="overflow-hidden rounded-2xl bg-surface shadow-xl ring-1 ring-border">
          <iframe
            class="airtable-embed"
            src="https://airtable.com/embed/appYhEd6T6ITLN80w/paguCaYXO2AOT1gEv/form"
            frameborder="0"
            width="100%"
            height="768"
            style="background: transparent; border: none;"
            title="Contact form">
          </iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Info Section -->
  <section class="bg-bg-base py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <div
          class="inline-flex items-center gap-2 rounded-full bg-primary-light px-4 py-1.5 text-sm font-medium text-primary">
          <span class="h-2 w-2 rounded-full bg-primary"></span>
          Contact Info
        </div>
        <h2
          class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl text-primary">
          Let's Talk About Your Project
        </h2>
        <p class="mt-4 text-lg leading-8 text-text-body">
          Ready to transform your space? Reach out and we'll get back to you
          with a free quote.
        </p>
      </div>

