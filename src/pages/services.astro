---
import Layout from "../layouts/Layout.astro";
import {
  Building2,
  Trash2,
  Truck,
  Drill,
  Shovel,
  Paintbrush,
} from "@lucide/astro";

interface ServiceItem {
  title: string;
  description: string;
  icon: typeof Building2;
}

const services: ServiceItem[] = [
  {
    title: "Non-Structural Demolition",
    description:
      "Complete interior, kitchen, and bathroom strip outs with precision.",
    icon: Building2,
  },
  {
    title: "Floor & Tile Removal",
    description: "Specialized removal of tiles, flooring, and adhesives.",
    icon: Trash2,
  },
  {
    title: "Debris Removal",
    description: "Efficient clearance of construction waste and rubble.",
    icon: Truck,
  },
  {
    title: "Concrete Cutting",
    description: "Diamond core drilling and precise concrete cutting.",
    icon: Drill,
  },
  {
    title: "Floor Grinding",
    description: "Concrete grinding and expert crack repair.",
    icon: Shovel,
  },
  {
    title: "Surface Preparation",
    description: "Comprehensive prep ready for your next renovation step.",
    icon: Paintbrush,
  },
];

const reasons = [
  "Clean, precise work focused on efficiency and quality",
  "Professional and punctual service throughout Perth",
  "Technical approach ensuring safe removal",
  "Viable options for your renovation project",
];

const videos = [
  {
    src: "https://ik.imagekit.io/137/rosco-sr/video6219997081453470100.mp4",
  },
  {
    src: "https://ik.imagekit.io/137/rosco-sr/video6305415180582919045.mp4",
  },
];

const renovations = [
  {
    src: "https://ik.imagekit.io/137/rosco-sr/Renovations/6257921321014595431.jpg",
    category: "Floor Renovation",
  },
  {
    src: "https://ik.imagekit.io/137/rosco-sr/Renovations/6257921321014595423.jpg",
    category: "Kitchen Renovation",
  },
  {
    src: "https://ik.imagekit.io/137/rosco-sr/Renovations/6257921321014595429.jpg",
    category: "Floor Renovation",
  },
  {
    src: "https://ik.imagekit.io/137/rosco-sr/Renovations/6257921321014595426.jpg",
    category: "Floor Renovation",
  },
  {
    src: "https://ik.imagekit.io/137/rosco-sr/Renovations/6257921321014595430.jpg",
    category: "Floor Renovation",
  },
  {
    src: "https://ik.imagekit.io/137/rosco-sr/Renovations/6257921321014595405.jpg",
    category: "Kitchen Renovation",
  },
  {
    src: "https://ik.imagekit.io/137/rosco-sr/Renovations/6257921321014595428.jpg",
    category: "Floor Renovation",
  },
  {
    src: "https://ik.imagekit.io/137/rosco-sr/Renovations/6257921321014595427.jpg",
    category: "Floor Renovation",
  },
  {
    src: "https://ik.imagekit.io/137/rosco-sr/Renovations/6257921321014595422.jpg",
    category: "Kitchen Renovation",
  },
  {
    src: "https://ik.imagekit.io/137/rosco-sr/Renovations/6257921321014595433.jpg",
    category: "Floor Renovation",
  },
  {
    src: "https://ik.imagekit.io/137/rosco-sr/Renovations/6257921321014595432.jpg",
    category: "Floor Renovation",
  },
  {
    src: "https://ik.imagekit.io/137/rosco-sr/Renovations/6257921321014595424.jpg",
    category: "Kitchen Renovation",
  },
];

const pageDescription =
  "ROSCO S&R offers professional strip out, non-structural demolition, kitchen renovations, floor renovations, floor and tile removal, debris removal, concrete cutting, floor grinding, and surface preparation services in Perth, WA.";
---

<Layout
  title="Services | Strip Out, Demolition, Removal & Renovation Perth"
  description={pageDescription}>
  <!-- Services Section -->
  <section class="bg-surface-alt py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl text-primary">
          Our Services
        </h2>
      </div>
      <div
        class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3">
        {
          services.map((service, i) => (
            <article
              class="group relative flex flex-col overflow-hidden rounded-2xl bg-surface shadow-sm ring-1 ring-border transition-all duration-500 hover:shadow-xl hover:-translate-y-1"
              style={`animation: fade-in-up 0.6s ease-out ${i * 0.1}s both`}>
              <div class="relative z-10 flex flex-col p-8 min-h-full">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-light text-primary transition-all duration-500 group-hover:scale-110 group-hover:bg-primary group-hover:text-white">
                  <service.icon class="h-6 w-6" />
                </div>
                <h3 class="mt-4 text-lg font-semibold leading-6 text-primary">
                  {service.title}
                </h3>
                <p class="mt-2 text-sm leading-6 text-subtitle">
                  {service.description}
                </p>
                <div class="mt-auto flex items-center pt-4">
                  <a
                    href="/contact"
                    class="inline-flex items-center gap-2 text-sm font-semibold leading-6 text-primary group/cta">
                    Get Quote{" "}
                    <span class="inline-block transition-transform duration-300 group-hover/cta:translate-x-1">
                      →
                    </span>
                  </a>
                </div>
              </div>
              <div class="absolute inset-0 z-0 bg-gradient-to-br from-primary/0 via-primary/0 to-primary/[0.02] opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Renovations Section -->
  <section
    class="bg-surface-alt py-16 sm:py-24"
    aria-label="Renovations showcase">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center mb-10 sm:mb-16">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl text-primary">
        Renovations
      </h2>
      <p class="mt-4 text-lg leading-8 text-text-body">
        See the quality of our renovation work
      </p>
    </div>

    <div
      class="swiper renovations-swiper h-[70vh] sm:h-[80vh] lg:h-[85vh] min-h-[400px] w-full lg:w-3xl shadow-2xl lg:rounded-xl">
      <div class="swiper-wrapper">
        {
          renovations.map((renovation) => (
            <div class="swiper-slide relative h-full w-full">
              <img
                src={renovation.src}
                alt={renovation.category}
                class="absolute inset-0 h-full w-full object-cover"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />
              <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-10 lg:p-16">
                <span class="inline-block rounded-full bg-white/20 backdrop-blur-md px-4 py-2 text-sm font-semibold text-white border border-white/30">
                  {renovation.category}
                </span>
              </div>
            </div>
          ))
        }
      </div>
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
      <div class="swiper-pagination"></div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="bg-surface-alt py-24 sm:py-32" aria-label="Why choose us">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:text-center">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl text-primary">
          Why Choose Us?
        </h2>
        <p class="mt-6 text-lg leading-8 text-text-body">
          At ROSCO S&R, we guarantee clean, precise work focused on efficiency
          and quality. We provide professional and punctual service throughout
          the Perth area.
        </p>
        <dl
          class="mx-auto mt-10 grid max-w-xl gap-6 sm:grid-cols-2 lg:max-w-none lg:grid-cols-4">
          {
            reasons.map((reason, i) => (
              <div
                class="flex flex-col items-center group relative rounded-xl bg-surface p-6 shadow-sm ring-1 ring-border transition-all duration-500 hover:shadow-md hover:-translate-y-0.5"
                style={`animation: fade-in-up 0.6s ease-out ${i * 0.1 + 0.4}s both`}>
                <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-light text-primary transition-all duration-300 group-hover:bg-primary group-hover:text-white">
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                    <path
                      fill-rule="evenodd"
                      d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </div>
                <dt class="text-sm font-semibold leading-6 text-primary">
                  {reason}
                </dt>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <div class="h-px w-full bg-border"></div>

  <!-- Video Section -->
  <section class="bg-surface-alt py-24 sm:py-32" aria-label="Video showcase">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl text-primary">
          See Our Work in Action
        </h2>
        <p class="mt-4 text-lg leading-8 text-text-body">
          Watch real footage from our recent projects across Perth.
        </p>
      </div>
      <div
        class="mx-auto mt-12 grid max-w-2xl grid-cols-1 gap-8 sm:grid-cols-2 lg:mx-0 lg:max-w-none">
        {
          videos.map((video) => (
            <div class="flex flex-col items-center gap-4">
              <div class="relative w-full max-w-xs overflow-hidden rounded-2xl bg-surface shadow-lg ring-1 ring-border">
                <video
                  src={video.src}
                  title="job"
                  class="h-[574px] w-full object-contain"
                  controls
                  playsinline
                  preload="none"
                />
              </div>
            </div>
          ))
        }
      </div>
      <div class="mt-20 text-center">
        <a
          href="/contact"
          class="group inline-flex items-center gap-3 rounded-xl bg-primary px-10 py-5 text-lg font-bold text-white shadow-xl shadow-primary/30 transition-all duration-300 hover:bg-primary-hover hover:shadow-2xl hover:shadow-primary/40 hover:-translate-y-0.5">
          Get a Free Quote <span
            class="inline-block transition-transform duration-300 group-hover:translate-x-1">
            →
          </span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .renovations-swiper .swiper-slide {
    background-color: #111827;
    overflow: hidden;
  }

  .renovations-swiper .swiper-button-prev,
  .renovations-swiper .swiper-button-next {
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 9999px;
    color: white !important;
    transition:
      background 0.3s ease,
      transform 0.3s ease;
  }
  .renovations-swiper .swiper-button-prev::after,
  .renovations-swiper .swiper-button-next::after {
    font-size: 16px;
    font-weight: bold;
  }
  .renovations-swiper .swiper-button-prev:hover,
  .renovations-swiper .swiper-button-next:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: scale(1.05);
  }

  .renovations-swiper .swiper-pagination {
    bottom: 20px !important;
    display: flex;
    justify-content: center;
    gap: 8px;
  }
  .renovations-swiper .swiper-pagination-bullet {
    width: 10px;
    height: 10px;
    background: rgba(255, 255, 255, 0.5);
    opacity: 1;
    border-radius: 9999px;
    transition: all 0.3s ease;
  }
  .renovations-swiper .swiper-pagination-bullet-active {
    width: 30px;
    background: white;
  }

  /* Cinematic effect kenburns */
  @keyframes kenburns {
    0% {
      transform: scale(1) translate(0, 0);
    }
    100% {
      transform: scale(1.12) translate(-1.5%, 1%);
    }
  }
  .renovations-swiper .swiper-slide-active img {
    animation: kenburns 6s ease-out forwards;
  }

  /*  Text Reveal */
  .renovations-swiper .swiper-slide .absolute.bottom-0 span {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .renovations-swiper .swiper-slide-active .absolute.bottom-0 span {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.3s;
  }
</style>

<script>
  import Swiper from "swiper/bundle";
  import "swiper/css/bundle";

  new Swiper(".renovations-swiper", {
    loop: true,
    effect: "fade",
    fadeEffect: { crossFade: true },
    autoplay: {
      delay: 2500,
      disableOnInteraction: false,
      pauseOnMouseEnter: false,
    },
    pagination: { el: ".swiper-pagination", clickable: true },
    navigation: {
      nextEl: ".swiper-button-next",
      prevEl: ".swiper-button-prev",
    },
  });
</script>
