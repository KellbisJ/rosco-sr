---
import Layout from "../layouts/Layout.astro";

const worksImgs: string[] = [
  "https://ik.imagekit.io/137/rosco-sr/1.webp",
  "https://ik.imagekit.io/137/rosco-sr/6.webp",
  "https://ik.imagekit.io/137/rosco-sr/2.webp",
  "https://ik.imagekit.io/137/rosco-sr/3.webp",
  "https://ik.imagekit.io/137/rosco-sr/12.webp",
  "https://ik.imagekit.io/137/rosco-sr/11.webp",
];

const worksLabels: string[] = [
  "Strip Out — Perth",
  "Strip Out — Perth",
  "Bathroom Removal — Perth",
  "Strip Out — Perth",
  "Surface Prep — Perth",
  "Strip Out — Perth",
];
---

<Layout
  title="ROSCO S&R | Strip Out, Removal & Renovation Services Perth"
  description="ROSCO S&R provides professional strip out, non-structural demolition, kitchen renovations, floor renovations, bathroom and kitchen removal, and surface preparation services across Perth, WA. Get a free quote today.">
  <div class="overflow-hidden bg-bg-base">
    <section class="relative bg-bg-base py-20 sm:py-32 overflow-hidden">
      <div
        class="absolute inset-0 opacity-[0.03] pointer-events-none"
        style="background-image: radial-gradient(circle, var(--color-primary) 1px, transparent 1px); background-size: 32px 32px;">
      </div>
      <div
        class="absolute -left-48 -top-48 h-96 w-96 rounded-full bg-primary/5 blur-3xl pointer-events-none">
      </div>
      <div
        class="absolute -bottom-48 -right-48 h-96 w-96 rounded-full bg-primary/5 blur-3xl pointer-events-none">
      </div>
      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <h1
            class="text-4xl font-bold tracking-tight sm:text-6xl text-primary">
            Professional Strip Out, Removal &amp; Renovation Services in Perth
          </h1>
          <p class="mt-6 text-lg leading-8 text-text-body">
            At ROSCO S&R, we specialize in kitchen renovations, floor renovations, and interior
            transformations, as well as strip outs and surface preparation in
            Perth. We are dedicated to facilitating your residential and
            commercial renovation projects with a technical, safe, and efficient
            approach.
          </p>
          <div class="mt-10 flex items-center justify-center gap-x-6">
            <a
              href="/contact"
              class="group inline-flex items-center gap-2 rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-primary/25 transition-all duration-300 hover:bg-primary-hover hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-offset-2 focus-visible:outline-primary">
              Get a Free Quote
              <span
                class="inline-block transition-transform duration-300 group-hover:translate-x-1"
                aria-hidden="true">
                →
              </span>
            </a>
            <a
              href="/services"
              class="group inline-flex items-center gap-2 text-sm font-semibold leading-6 text-primary transition-all duration-300 hover:text-primary-hover">
              Explore Services
              <span
                class="inline-block transition-transform duration-300 group-hover:translate-x-1"
                aria-hidden="true">
                →
              </span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-bg-base py-20 sm:py-28" aria-label="Project gallery">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2
            class="text-3xl font-bold tracking-tight sm:text-4xl text-primary">
            Our Work
          </h2>
          <p class="mt-4 text-lg leading-8 text-text-body">
            A glimpse into our recent strip out, removal, and renovation projects across
            Perth.
          </p>
        </div>
        <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {
            worksImgs.map((src, index) => (
              <div
                class="group relative overflow-hidden rounded-2xl bg-surface-alt shadow-lg ring-1 ring-border aspect-[3/4]"
                role="listitem"
                style={`animation: fade-in-up 0.6s ease-out ${index * 0.1}s both`}>
                <img
                  src={src}
                  alt={worksLabels[index]}
                  class="h-full w-full object-cover transition-all duration-500 group-hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent opacity-60 transition-opacity duration-300 group-hover:opacity-100" />
                <div class="absolute bottom-0 left-0 right-0 p-5 translate-y-1 transition-all duration-300 group-hover:translate-y-0">
                  <p class="text-sm font-semibold text-white drop-shadow-md">
                    {worksLabels[index]}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</Layout>
