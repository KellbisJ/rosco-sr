---
// src/components/Footer.astro
const footerLinks = {
  company: [{ label: "About ROSCO S&R", href: "/about" }],
  services: [
    { label: "Kitchen Renovations", href: "/services" },
    { label: "Floor Renovations", href: "/services" },
    { label: "Kitchen & Bathroom Removal", href: "/services" },
    { label: "Floor & Tile Removal", href: "/services" },
    { label: "Light Demolition (Non-Structural)", href: "/services" },
    { label: "Rubbish Removal & Cleaning", href: "/services" },
  ],
  contact: [
    { label: "Perth, WA", href: "/contact" },
    {
      label: "rosco.s.r.service@gmail.com",
      href: "mailto:rosco.s.r.service@gmail.com",
    },
  ],
};
---

<footer class="border-t bg-surface py-12 border-border">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-muted">
          ROSCO S&R
        </h3>
        <p class="mt-4 text-sm text-secondary">
          Professional strip out, non-structural demolition, kitchen renovations, floor renovations, and removal
          services in Perth, Western Australia.
        </p>
        <p class="mt-2 text-sm text-secondary">
          <a href="tel:+61406917864" class="hover:text-primary">
            +61 406 917 864
          </a>
        </p>
      </div>
      {
        Object.entries(footerLinks).map(([category, links]) => (
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-muted">
              {category}
            </h3>
            <ul class="mt-4 space-y-2" aria-label={`${category} links`}>
              {links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-secondary transition-colors hover:underline">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <div class="mt-12 border-t pt-8 border-border">
      <p class="text-xs text-center text-muted">
        &copy; {new Date().getFullYear()} ROSCO S&R. All rights reserved. Perth, Western
        Australia.
      </p>
    </div>
  </div>
</footer>
