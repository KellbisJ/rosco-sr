---
const navLinks = [
  { label: "Home", href: "/" },
  { label: "Services", href: "/services" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];

const logo = "https://ik.imagekit.io/137/rosco-sr/rosco-sr.png";
---

<header
  class="sticky top-0 z-50 w-full border-b bg-surface/80 backdrop-blur-sm border-border">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-2">
    <a href="/" class="shrink-0 leading-none" aria-label="ROSCO S&R Home">
      <img src={logo} alt="ROSCO S&R Logo" class="h-12 w-auto object-contain" />
    </a>
    <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-secondary transition-colors hover:text-primary hover:underline">
            {link.label}
          </a>
        ))
      }
    </nav>
    <a
      href="/contact"
      class="inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-semibold text-white bg-primary transition-colors hover:bg-primary-hover focus-visible:outline focus-visible:outline-offset-2 focus-visible:outline-primary">
      Get a Quote
    </a>
  </div>
</header>
